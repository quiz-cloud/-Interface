<view class="page">
	<view class="card">
		<view class="title">预约设备</view>
		<view class="meta">{{machineName}}</view>
		<view class="meta">{{dateLabel}}</view>

		<view class="slot-list">
			<view
				class="slot {{item.status}} {{selectedSlotIndex === index ? 'is-selected' : ''}}"
				wx:for="{{timeSlots}}"
				wx:key="index"
				data-index="{{index}}"
				bindtap="onSlotTap"
			>
				<text class="slot-time">{{item.label}}</text>
				<text class="slot-status">{{item.status === 'free' ? '空闲' : '已预约'}}</text>
			</view>
		</view>

		<view class="file-row">
			<view class="upload-btn" bindtap="onUploadFileTap">上传加工文件</view>
			<text class="file-name">{{processingFileName || '未上传文件'}}</text>
		</view>

		<view class="confirm-btn" bindtap="onConfirmTap">确认预约</view>
	</view>
</view>