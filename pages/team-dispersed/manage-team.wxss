/* pages/team-dispersed/manage-team.wxss */
.container {
  background-color: #fff3e0;
  min-height: 100vh;
  padding: 20rpx;
}

.page-header {
  margin-bottom: 32rpx;
  padding: 0 16rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.page-subtitle {
  font-size: 28rpx;
  color: #999;
}

/* 卡片通用样式 */
.info-card,
.members-card,
.applications-card,
.danger-zone {
  background-color: #fff;
  border-radius: 15rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.member-count {
  font-size: 26rpx;
  color: #999;
  margin-left: 10rpx;
}

/* 队伍信息卡片 */
.info-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item:last-of-type {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666;
  width: 160rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  text-align: right;
  word-break: break-all;
}

.edit-btn {
  width: 100%;
  margin-top: 20rpx;
  background-color: #f7b500;
  color: #fff;
  border-radius: 10rpx;
  font-size: 28rpx;
  font-weight: bold;
  padding: 20rpx 0;
}

/* 成员列表 */
.member-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.member-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background-color: #fafafa;
  border-radius: 12rpx;
}

.member-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.member-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #e9e9e9;
  margin-right: 20rpx;
}

.member-detail {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.member-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.member-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.role-tag {
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
}

.captain-tag {
  background-color: #fff3e0;
  color: #f7b500;
}

.member-tag {
  background-color: #f0f0f0;
  color: #666;
}

.member-id {
  font-size: 24rpx;
  color: #999;
}

.member-actions {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.action-btn {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
}

.transfer-btn {
  background-color: #007aff;
  color: #fff;
}

.remove-btn {
  background-color: #ff3b30;
  color: #fff;
}

/* 入队申请 */
.badge {
  background-color: #ff3b30;
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  margin-left: 10rpx;
}

.application-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.application-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background-color: #fafafa;
  border-radius: 12rpx;
}

.applicant-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.applicant-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #e9e9e9;
  margin-right: 20rpx;
}

.applicant-detail {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.applicant-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.applicant-id,
.apply-time {
  font-size: 24rpx;
  color: #999;
}

.application-actions {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.approve-btn {
  background-color: #28a745;
  color: #fff;
}

.reject-btn {
  background-color: #6c757d;
  color: #fff;
}

/* 危险操作区 */
.danger-title {
  color: #ff3b30;
}

.danger-btn {
  width: 100%;
  margin-top: 15rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
  font-weight: bold;
  padding: 20rpx 0;
}

.quit-btn {
  background-color: #fff;
  color: #ff9500;
  border: 2rpx solid #ff9500;
}

.dissolve-btn {
  background-color: #ff3b30;
  color: #fff;
}

/* 编辑弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 600rpx;
  background-color: #fff;
  border-radius: 20rpx;
  overflow: hidden;
}

.modal-header {
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
}

.modal-body {
  padding: 30rpx;
}

.form-item {
  margin-bottom: 30rpx;
  position: relative;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 15rpx;
  font-weight: bold;
}

.form-input,
.form-textarea {
  width: 100%;
  padding: 20rpx;
  background-color: #f5f5f5;
  border-radius: 10rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.form-textarea {
  min-height: 150rpx;
}

.char-count {
  position: absolute;
  right: 10rpx;
  bottom: 10rpx;
  font-size: 22rpx;
  color: #999;
}

.picker-view {
  padding: 20rpx;
  background-color: #f5f5f5;
  border-radius: 10rpx;
  font-size: 28rpx;
  color: #333;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
}

.modal-btn {
  flex: 1;
  padding: 30rpx 0;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 0;
}

.cancel-btn {
  background-color: #fff;
  color: #666;
  border-right: 1rpx solid #f0f0f0;
}

.confirm-btn {
  background-color: #fff;
  color: #f7b500;
}

