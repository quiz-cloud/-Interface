page {
  --primary-color: #FFB800;
  --primary-dark: #E6A600;
  --gray: #999999;
  --light-gray: #F5F5F5;
  background-color: #fbf4e6;
}

.page {
  padding: 24rpx 24rpx 140rpx;
  box-sizing: border-box;
}

.search-bar {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.search-input {
  flex: 1;
  height: 72rpx;
  background: #fff;
  border-radius: 999rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.05);
}

.search-btn {
  width: 120rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border-radius: 999rpx;
  color: #fff;
  background: linear-gradient(135deg, #FFB800 0%, #FF9500 100%);
  font-size: 28rpx;
  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.05);
}

.tabs {
  margin-top: 18rpx;
  display: flex;
  gap: 16rpx;
}

.tab {
  flex: 1;
  text-align: center;
  height: 72rpx;
  line-height: 72rpx;
  background: #fff;
  border-radius: 18rpx;
  color: #555;
  font-size: 28rpx;
  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.04);
}

.tab.active {
  color: #fff;
  background: linear-gradient(135deg, #FFB800 0%, #FF9500 100%);
}

.filters {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.filter-pill {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  background: #fff;
  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.04);
}

.filter-text {
  font-size: 26rpx;
  color: #333;
}

.filter-arrow {
  font-size: 20rpx;
  color: #999;
}

.hint {
  font-size: 24rpx;
  color: var(--gray);
}

.list {
  margin-top: 18rpx;
}

.post {
  background: #fff;
  border-radius: 22rpx;
  padding: 24rpx;
  margin-bottom: 18rpx;
  box-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.05);
}

.post-header {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: var(--light-gray);
  flex-shrink: 0;
}

.meta {
  flex: 1;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.author {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.time {
  font-size: 24rpx;
  color: #999;
}

.row2 {
  margin-top: 8rpx;
}

.tag {
  display: inline-flex;
  padding: 6rpx 14rpx;
  font-size: 22rpx;
  border-radius: 999rpx;
  background: #FFF8E7;
  color: var(--primary-dark);
}

.post-body {
  margin-top: 18rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 10rpx;
}

.content {
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.post-footer {
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #f2f2f2;
  display: flex;
  justify-content: flex-end;
  gap: 28rpx;
}

.stat {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  color: #666;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.stat-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
}

.like.liked .stat-value {
  color: #E64340;
}

.empty {
  background: #fff;
  border-radius: 22rpx;
  padding: 60rpx 30rpx;
  text-align: center;
  color: #666;
  box-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.04);
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.empty-sub {
  margin-top: 14rpx;
  font-size: 26rpx;
  color: #999;
}

.loadmore {
  text-align: center;
  padding: 20rpx 0;
  font-size: 24rpx;
  color: #999;
}

.fab {
  position: fixed;
  right: 28rpx;
  bottom: 170rpx;
  width: 104rpx;
  height: 104rpx;
  border-radius: 52rpx;
  background: linear-gradient(135deg, #FFB800 0%, #FF9500 100%);
  box-shadow: 0 14rpx 30rpx rgba(255, 184, 0, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
}

.fab-plus {
  color: #fff;
  font-size: 54rpx;
  line-height: 1;
}