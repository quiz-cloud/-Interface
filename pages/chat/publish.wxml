<!-- pages/chat/publish.wxml -->
<view class="page">
  <view class="card">
    <view class="label">课程分类</view>
    <picker mode="selector" range="{{courseOptions}}" value="{{courseIndex}}" bindchange="onCourseChange">
      <view class="picker">
        <text class="picker-text">{{courseOptions[courseIndex]}}</text>
        <text class="picker-arrow">▼</text>
      </view>
    </picker>

    <view class="label">标题</view>
    <input class="input" placeholder="一句话概括你想讨论的内容" value="{{title}}" bindinput="onTitleInput" maxlength="30" />
    <view class="counter">{{title.length}} / 30</view>

    <view class="label">内容</view>
    <textarea class="textarea" placeholder="详细描述问题/经验，越具体越容易得到回复" value="{{content}}" bindinput="onContentInput" maxlength="300" />
    <view class="counter">{{content.length}} / 300</view>

    <view class="actions">
      <button class="btn ghost" bindtap="cancel">取消</button>
      <button class="btn primary" bindtap="submit" disabled="{{submitting}}">发布</button>
    </view>
  </view>
</view>

