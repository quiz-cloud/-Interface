<!-- pages/chat/chat.wxml -->
<view class="page">
  <view class="search-bar">
    <input
      class="search-input"
      placeholder="搜索帖子标题/内容"
      value="{{keyword}}"
      confirm-type="search"
      bindinput="onKeywordInput"
      bindconfirm="onSearchConfirm"
    />
    <view class="search-btn" bindtap="onSearchConfirm">搜索</view>
  </view>

  <view class="tabs">
    <view class="tab {{activeTab === 'latest' ? 'active' : ''}}" bindtap="switchTab" data-tab="latest">最新</view>
    <view class="tab {{activeTab === 'hot' ? 'active' : ''}}" bindtap="switchTab" data-tab="hot">热门</view>
    <view class="tab {{activeTab === 'mine' ? 'active' : ''}}" bindtap="switchTab" data-tab="mine">我的</view>
  </view>

  <view class="filters">
    <picker mode="selector" range="{{courseOptions}}" value="{{courseIndex}}" bindchange="onCourseChange">
      <view class="filter-pill">
        <text class="filter-text">{{courseOptions[courseIndex]}}</text>
        <text class="filter-arrow">▼</text>
      </view>
    </picker>
    <view class="hint">{{statusText}}</view>
  </view>

  <view class="list">
    <block wx:if="{{displayPosts.length === 0}}">
      <view class="empty">
        <view class="empty-title">暂无内容</view>
        <view class="empty-sub">试试切换分类/清空搜索，或者发一条帖子</view>
      </view>
    </block>

    <block wx:for="{{displayPosts}}" wx:key="id">
      <view class="post" bindtap="openDetail" data-id="{{item.id}}">
        <view class="post-header">
          <image class="avatar" src="{{item.authorAvatar}}" mode="aspectFill"></image>
          <view class="meta">
            <view class="row">
              <text class="author">{{item.authorName}}</text>
              <text class="time">{{item.timeText}}</text>
            </view>
            <view class="row2">
              <view class="tag">{{item.course}}</view>
            </view>
          </view>
        </view>

        <view class="post-body">
          <view class="title">{{item.title}}</view>
          <view class="content">{{item.content}}</view>
        </view>

        <view class="post-footer" catchtap="noop">
          <view class="stat">
            <text class="stat-label">评论</text>
            <text class="stat-value">{{item.commentCount}}</text>
          </view>
          <view class="stat like {{item.likedByMe ? 'liked' : ''}}" bindtap="toggleLike" data-id="{{item.id}}">
            <text class="stat-label">赞</text>
            <text class="stat-value">{{item.likeCount}}</text>
          </view>
        </view>
      </view>
    </block>

    <view class="loadmore" wx:if="{{displayPosts.length > 0}}">
      <text wx:if="{{hasMore}}">上拉加载更多</text>
      <text wx:else>没有更多了</text>
    </view>
  </view>

  <view class="fab" bindtap="goPublish">
    <text class="fab-plus">＋</text>
  </view>
</view>