page {
  --primary-color: #FFB800;
  --primary-dark: #E6A600;
  --gray: #999999;
  background-color: #fbf4e6;
}

.page {
  padding: 24rpx;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 22rpx;
  padding: 28rpx;
  box-shadow: 0 10rpx 26rpx rgba(0, 0, 0, 0.05);
}

.label {
  margin-top: 18rpx;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  color: #666;
}

.picker {
  height: 76rpx;
  border-radius: 16rpx;
  background: #fafafa;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 18rpx;
  box-sizing: border-box;
}

.picker-text {
  font-size: 28rpx;
  color: #333;
}

.picker-arrow {
  font-size: 20rpx;
  color: #999;
}

.input {
  height: 76rpx;
  border-radius: 16rpx;
  background: #fafafa;
  padding: 0 18rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.textarea {
  min-height: 260rpx;
  border-radius: 16rpx;
  background: #fafafa;
  padding: 18rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  width: 100%;
}

.counter {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #aaa;
  text-align: right;
}

.actions {
  display: flex;
  gap: 16rpx;
  margin-top: 26rpx;
}

.btn {
  flex: 1;
  height: 78rpx;
  line-height: 78rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  padding: 0;
}

.btn::after {
  border: none;
}

.btn.ghost {
  border: 2rpx solid var(--primary-color);
  color: var(--primary-color);
  background: #fff;
}

.btn.primary {
  color: #fff;
  background: linear-gradient(135deg, #FFB800 0%, #FF9500 100%);
}

.btn.primary[disabled] {
  background: #ddd;
  color: #fff;
}

