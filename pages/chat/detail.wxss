page {
  --primary-color: #FFB800;
  --primary-dark: #E6A600;
  --gray: #999999;
  --light-gray: #F5F5F5;
  background-color: #fbf4e6;
}

.page {
  padding: 24rpx 24rpx 130rpx;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 22rpx;
  padding: 24rpx;
  box-shadow: 0 10rpx 26rpx rgba(0, 0, 0, 0.05);
}

.post-header {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: var(--light-gray);
  flex-shrink: 0;
}

.meta {
  flex: 1;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.author {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
}

.time {
  font-size: 24rpx;
  color: #999;
}

.tag {
  margin-top: 10rpx;
  display: inline-flex;
  padding: 6rpx 14rpx;
  font-size: 22rpx;
  border-radius: 999rpx;
  background: #FFF8E7;
  color: var(--primary-dark);
}

.title {
  margin-top: 20rpx;
  font-size: 36rpx;
  font-weight: 800;
  color: #222;
}

.content {
  margin-top: 14rpx;
  font-size: 28rpx;
  color: #555;
  line-height: 1.75;
  white-space: pre-wrap;
}

.actions {
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #f2f2f2;
  display: flex;
  gap: 18rpx;
  justify-content: flex-end;
}

.pill {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #fafafa;
  color: #666;
}

.pill-label {
  font-size: 24rpx;
  color: #999;
}

.pill-value {
  font-size: 28rpx;
  font-weight: 800;
  color: #333;
}

.pill.like.liked .pill-value {
  color: #E64340;
}

.section {
  margin-top: 18rpx;
}

.section-title {
  padding: 6rpx 6rpx 14rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
}

.comment {
  background: #fff;
  border-radius: 18rpx;
  padding: 18rpx;
  margin-bottom: 14rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.04);
}

.comment-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.comment-author {
  font-size: 26rpx;
  font-weight: 700;
  color: #333;
}

.comment-time {
  font-size: 22rpx;
  color: #999;
}

.comment-content {
  font-size: 28rpx;
  color: #555;
  line-height: 1.65;
  white-space: pre-wrap;
}

.empty {
  margin: 6rpx;
  padding: 30rpx 0;
  text-align: center;
  color: #999;
  font-size: 26rpx;
}

.composer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18rpx 20rpx 22rpx;
  background: rgba(251, 244, 230, 0.98);
  backdrop-filter: blur(8px);
  display: flex;
  gap: 14rpx;
  box-sizing: border-box;
}

.composer-input {
  flex: 1;
  height: 74rpx;
  background: #fff;
  border-radius: 999rpx;
  padding: 0 22rpx;
  font-size: 28rpx;
  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.05);
}

.composer-btn {
  width: 120rpx;
  height: 74rpx;
  line-height: 74rpx;
  text-align: center;
  border-radius: 999rpx;
  background: #ddd;
  color: #fff;
  font-size: 28rpx;
}

.composer-btn.active {
  background: linear-gradient(135deg, #FFB800 0%, #FF9500 100%);
}

.loading {
  padding: 80rpx 0;
  text-align: center;
  color: #999;
  font-size: 26rpx;
}

