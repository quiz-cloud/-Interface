<!-- pages/chat/detail.wxml -->
<view class="page" wx:if="{{post}}">
  <view class="card">
    <view class="post-header">
      <image class="avatar" src="{{post.authorAvatar}}" mode="aspectFill"></image>
      <view class="meta">
        <view class="row">
          <text class="author">{{post.authorName}}</text>
          <text class="time">{{post.timeText}}</text>
        </view>
        <view class="tag">{{post.course}}</view>
      </view>
    </view>

    <view class="title">{{post.title}}</view>
    <view class="content">{{post.content}}</view>

    <view class="actions">
      <view class="pill">
        <text class="pill-label">评论</text>
        <text class="pill-value">{{post.commentCount}}</text>
      </view>
      <view class="pill like {{post.likedByMe ? 'liked' : ''}}" bindtap="toggleLike">
        <text class="pill-label">赞</text>
        <text class="pill-value">{{post.likeCount}}</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">评论（{{post.commentCount}}）</view>
    <block wx:if="{{post.comments.length === 0}}">
      <view class="empty">还没有评论，来抢沙发吧</view>
    </block>
    <block wx:for="{{post.comments}}" wx:key="id">
      <view class="comment">
        <view class="comment-top">
          <text class="comment-author">{{item.authorName}}</text>
          <text class="comment-time">{{item.timeText}}</text>
        </view>
        <view class="comment-content">{{item.content}}</view>
      </view>
    </block>
  </view>

  <view class="composer">
    <input class="composer-input" placeholder="写下你的回复…" value="{{commentText}}" bindinput="onCommentInput" />
    <view class="composer-btn {{commentText.trim() ? 'active' : ''}}" bindtap="submitComment">发送</view>
  </view>
</view>

<view class="page" wx:else>
  <view class="loading">加载中…</view>
</view>

