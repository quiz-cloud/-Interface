<!--pages/login/login.wxml-->
<view class="page">
  <view class="header">
    <text class="title">登录</text>
    <text class="subtitle">Sign in to continue</text>
  </view>

  <form class="card" bindsubmit="handleSubmit">
    <view class="form-item">
      <text class="label">学号</text>
      <input class="input" name="studentId" placeholder="请输入学号" maxlength="20" />
    </view>
    <view class="form-item">
      <text class="label">密码</text>
      <input class="input" name="password" password placeholder="请输入密码" maxlength="20" />
    </view>

    <button class="submit-btn" form-type="submit">登录</button>
  </form>

  <view class="hint">账号验证功能待接入</view>
</view>
