.container {
  padding: 24rpx;
  background-color: #FFFBF0; /* consistent with prior visual standards styling */
  min-height: 100vh;
  box-sizing: border-box;
}

.history-list {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.history-card {
  width: 680rpx;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  padding: 30rpx;
  box-sizing: border-box;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.apply-type {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.status-tag {
  height: 44rpx;
  line-height: 44rpx;
  padding: 0 16rpx;
  font-size: 24rpx;
  color: #FFFFFF;
  border-radius: 22rpx;
}

.status-pending {
  background-color: #5B8FF9; /* 蓝 */
}

.status-approved {
  background-color: #52C41A; /* 绿 */
}

.status-rejected {
  background-color: #FF4D4F; /* 红 */
}

.card-body {
  display: flex;
  flex-direction: column;
}

.info-row {
  display: flex;
  margin-bottom: 12rpx;
  align-items: flex-start;
}

.info-row:last-child {
  margin-bottom: 0;
}

.label {
  width: 140rpx;
  font-size: 28rpx;
  color: #999999;
  flex-shrink: 0;
}

.value {
  font-size: 28rpx;
  color: #333333;
  flex: 1;
}

.reason-text {
  font-weight: bold;
  color: #333333;
}

.empty-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding-top: 100rpx;
  font-size: 30rpx;
  color: #999999;
}
