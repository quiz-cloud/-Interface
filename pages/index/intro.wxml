<view class="page">
  <view class="header">
    <text class="title">课程介绍</text>
    <text class="subtitle">左右滑动或点击按钮切换课程</text>
  </view>

  <swiper
    class="course-swiper"
    current="{{currentIndex}}"
    bindchange="onSwiperChange"
    circular="false"
    indicator-dots="false"
  >
    <block wx:for="{{courses}}" wx:key="name">
      <swiper-item>
        <view class="card">
          <view class="tag">{{item.short}}</view>
          <view class="name">{{item.name}}</view>
          <view class="divider"></view>
          <view class="desc">{{item.description}}</view>
          <view class="index">第 {{index + 1}} / {{courses.length}} 门</view>
        </view>
      </swiper-item>
    </block>
  </swiper>

  <view class="pager">
    <button class="pager-btn" bindtap="goPrev" disabled="{{currentIndex === 0}}">上一门</button>
    <view class="dots">
      <block wx:for="{{courses}}" wx:key="name">
        <view class="dot {{index === currentIndex ? 'active' : ''}}"></view>
      </block>
    </view>
    <button class="pager-btn primary" bindtap="goNext" disabled="{{currentIndex === courses.length - 1}}">下一门</button>
  </view>
</view>

