page {
  --primary-color: #FFB800;
  --primary-dark: #E6A600;
  --gray: #999999;
  --light-gray: #F5F5F5;
  background-color: #fbf4e6;
}

.page {
  padding: 40rpx 30rpx 60rpx;
  box-sizing: border-box;
}

.header {
  margin-bottom: 30rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.subtitle {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: var(--gray);
}

.course-swiper {
  height: 520rpx;
}

.card {
  margin-top: 20rpx;
  background-color: #fff;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 100%;
  box-sizing: border-box;
}

.tag {
  display: inline-flex;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: #FFF8E7;
  color: var(--primary-dark);
  font-size: 24rpx;
}

.name {
  margin-top: 24rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
}

.divider {
  margin: 24rpx 0;
  height: 4rpx;
  width: 80rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, var(--primary-color), var(--primary-dark));
}

.desc {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
  flex: 1;
}

.index {
  margin-top: 24rpx;
  font-size: 26rpx;
  color: var(--gray);
  text-align: right;
}

.pager {
  margin-top: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.pager-btn {
  flex: 0 0 180rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 999rpx;
  border: 2rpx solid var(--primary-color);
  background-color: #fff;
  color: var(--primary-color);
  font-size: 28rpx;
  text-align: center;
  padding: 0;
}

.pager-btn::after {
  border: none;
}

.pager-btn[disabled] {
  border-color: #ddd;
  color: #ccc;
}

.pager-btn.primary {
  background: linear-gradient(135deg, #FFB800 0%, #FF9500 100%);
  color: #fff;
  border: none;
}

.pager-btn.primary[disabled] {
  background: #ddd;
  color: #fff;
}

.dots {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 10rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: #ddd;
}

.dot.active {
  width: 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #FFB800 0%, #FF9500 100%);
}

