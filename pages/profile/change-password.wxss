/* pages/profile/change-password.wxss */
.container {
  min-height: 100vh;
  background-color: #fbf4e6;
  padding: 24rpx;
  padding-bottom: 40rpx;
}

.page-header {
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.page-subtitle {
  font-size: 28rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

/* 安全提示卡片 */
.tips-card {
  background: linear-gradient(135deg, #FFF8E7 0%, #FFE8B8 100%);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 18rpx rgba(255, 184, 0, 0.15);
}

.tips-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.tips-icon {
  font-size: 32rpx;
}

.tips-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.tips-item {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

/* 表单卡片 */
.form-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.05);
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.label-icon {
  font-size: 28rpx;
}

.label-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.required {
  color: #ff3b30;
  font-size: 28rpx;
}

.input-wrapper {
  position: relative;
  display: flex;
  align-items: center;
}

.form-input {
  flex: 1;
  height: 88rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 0 80rpx 0 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.eye-icon {
  position: absolute;
  right: 24rpx;
  font-size: 36rpx;
  padding: 10rpx;
}

/* 密码强度指示器 */
.password-strength {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 12rpx;
}

.strength-bar {
  flex: 1;
  height: 8rpx;
  background: #e0e0e0;
  border-radius: 4rpx;
  overflow: hidden;
}

.strength-fill {
  height: 100%;
  border-radius: 4rpx;
  transition: all 0.3s;
}

.strength-fill.weak {
  width: 33%;
  background: #ff3b30;
}

.strength-fill.medium {
  width: 66%;
  background: #FFB800;
}

.strength-fill.strong {
  width: 100%;
  background: #52c41a;
}

.strength-text {
  font-size: 24rpx;
  font-weight: bold;
  min-width: 40rpx;
}

/* 密码匹配提示 */
.match-hint {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 12rpx;
}

.match-icon {
  font-size: 28rpx;
}

.match-text {
  font-size: 24rpx;
  font-weight: 500;
}

.match-text.match {
  color: #52c41a;
}

.match-text.mismatch {
  color: #ff3b30;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #FFB800 0%, #FF9500 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
  box-shadow: 0 8rpx 20rpx rgba(255, 184, 0, 0.3);
}

.reset-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #fff;
  color: #666;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: 2rpx solid #e0e0e0;
}

/* 忘记密码提示 */
.forgot-password {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 32rpx 20rpx;
}

.forgot-icon {
  font-size: 28rpx;
}

.forgot-text {
  font-size: 26rpx;
  color: #999;
}

