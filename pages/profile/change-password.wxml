<!--pages/profile/change-password.wxml-->
<view class="container">
  <view class="page-header">
    <text class="page-title">修改密码</text>
    <text class="page-subtitle">Change Password</text>
  </view>

  <!-- 安全提示 -->
  <view class="tips-card">
    <view class="tips-header">
      <text class="tips-icon">🔐</text>
      <text class="tips-title">安全提示</text>
    </view>
    <view class="tips-list">
      <text class="tips-item">• 密码长度为6-20位</text>
      <text class="tips-item">• 必须包含字母和数字</text>
      <text class="tips-item">• 建议定期更换密码</text>
    </view>
  </view>

  <!-- 密码输入表单 -->
  <view class="form-card">
    <!-- 原密码 -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-icon">🔑</text>
        <text class="label-text">原密码</text>
        <text class="required">*</text>
      </view>
      <view class="input-wrapper">
        <input 
          class="form-input" 
          type="{{showOldPassword ? 'text' : 'password'}}"
          placeholder="请输入原密码"
          value="{{oldPassword}}"
          bindinput="onOldPasswordInput"
          maxlength="20"
        />
        <view class="eye-icon" bindtap="togglePasswordVisibility" data-field="showOldPassword">
          {{showOldPassword ? '👁️' : '👁️‍🗨️'}}
        </view>
      </view>
    </view>

    <!-- 新密码 -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-icon">🆕</text>
        <text class="label-text">新密码</text>
        <text class="required">*</text>
      </view>
      <view class="input-wrapper">
        <input 
          class="form-input" 
          type="{{showNewPassword ? 'text' : 'password'}}"
          placeholder="请输入新密码"
          value="{{newPassword}}"
          bindinput="onNewPasswordInput"
          maxlength="20"
        />
        <view class="eye-icon" bindtap="togglePasswordVisibility" data-field="showNewPassword">
          {{showNewPassword ? '👁️' : '👁️‍🗨️'}}
        </view>
      </view>
      <view class="password-strength" wx:if="{{newPassword.length > 0}}">
        <view class="strength-bar">
          <view class="strength-fill {{passwordStrength}}"></view>
        </view>
        <text class="strength-text">{{passwordStrengthText}}</text>
      </view>
    </view>

    <!-- 确认密码 -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-icon">✅</text>
        <text class="label-text">确认密码</text>
        <text class="required">*</text>
      </view>
      <view class="input-wrapper">
        <input 
          class="form-input" 
          type="{{showConfirmPassword ? 'text' : 'password'}}"
          placeholder="请再次输入新密码"
          value="{{confirmPassword}}"
          bindinput="onConfirmPasswordInput"
          maxlength="20"
        />
        <view class="eye-icon" bindtap="togglePasswordVisibility" data-field="showConfirmPassword">
          {{showConfirmPassword ? '👁️' : '👁️‍🗨️'}}
        </view>
      </view>
      <view class="match-hint" wx:if="{{confirmPassword.length > 0}}">
        <text class="match-icon">{{isPasswordMatch ? '✓' : '✗'}}</text>
        <text class="match-text {{isPasswordMatch ? 'match' : 'mismatch'}}">
          {{isPasswordMatch ? '密码一致' : '密码不一致'}}
        </text>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-buttons">
    <button class="submit-btn" bindtap="submitPassword">确认修改</button>
    <button class="reset-btn" bindtap="resetForm">重置</button>
  </view>

  <!-- 忘记密码提示 -->
  <view class="forgot-password">
    <text class="forgot-icon">❓</text>
    <text class="forgot-text">忘记原密码？请联系管理员重置</text>
  </view>
</view>

