<!--pages/profile/about.wxml-->
<view class="container">
  <!-- 应用信息 -->
  <view class="app-info-card">
    <image class="app-logo" src="{{appInfo.logo}}" mode="aspectFit" />
    <text class="app-name">{{appInfo.name}}</text>
    <text class="app-version">{{appInfo.version}}</text>
    <view class="app-desc">
      <text class="desc-text">为工程创新训练课程打造的综合服务平台</text>
    </view>
  </view>

  <!-- 核心功能 -->
  <view class="section-card">
    <view class="section-header">
      <text class="section-icon">✨</text>
      <text class="section-title">核心功能</text>
    </view>
    <view class="features-grid">
      <view class="feature-item" wx:for="{{features}}" wx:key="title">
        <text class="feature-icon">{{item.icon}}</text>
        <text class="feature-title">{{item.title}}</text>
        <text class="feature-desc">{{item.desc}}</text>
      </view>
    </view>
  </view>

  <!-- 团队介绍 -->
  <view class="section-card">
    <view class="section-header">
      <text class="section-icon">👨‍💻</text>
      <text class="section-title">开发团队</text>
    </view>
    <view class="team-list">
      <view class="team-item" wx:for="{{teamMembers}}" wx:key="role">
        <view class="team-role">{{item.role}}</view>
        <view class="team-name">{{item.name}}</view>
      </view>
    </view>
  </view>

  <!-- 联系方式 -->
  <view class="section-card">
    <view class="section-header">
      <text class="section-icon">📮</text>
      <text class="section-title">联系我们</text>
    </view>
    <view class="contact-list">
      <view class="contact-item" bindtap="copyContact" data-type="email">
        <view class="contact-left">
          <text class="contact-icon">📧</text>
          <view class="contact-info">
            <text class="contact-label">邮箱</text>
            <text class="contact-value">{{contactInfo.email}}</text>
          </view>
        </view>
        <text class="contact-action">复制</text>
      </view>
      <view class="contact-item" bindtap="copyContact" data-type="wechat">
        <view class="contact-left">
          <text class="contact-icon">💬</text>
          <view class="contact-info">
            <text class="contact-label">微信客服</text>
            <text class="contact-value">{{contactInfo.wechat}}</text>
          </view>
        </view>
        <text class="contact-action">复制</text>
      </view>
    </view>
  </view>

  <!-- 其他信息 -->
  <view class="action-card">
    <view class="action-item" bindtap="checkUpdate">
      <text class="action-text">检查更新</text>
      <view class="action-right">
        <text class="action-value">{{appInfo.version}}</text>
        <text class="action-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 版权信息 -->
  <view class="copyright">
    <text class="copyright-text">© 2024 实验助手平台</text>
    <text class="copyright-text">All Rights Reserved</text>
  </view>
</view>

