/* pages/profile/about.wxss */
.container {
  min-height: 100vh;
  background-color: #fbf4e6;
  padding: 24rpx;
  padding-bottom: 40rpx;
}

/* 应用信息卡片 */
.app-info-card {
  background: linear-gradient(135deg, #FFF8E7 0%, #FFE8B8 100%);
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 184, 0, 0.2);
}

.app-logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 32rpx;
  background: #fff;
  padding: 20rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 24rpx;
}

.app-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.app-version {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.app-desc {
  text-align: center;
}

.desc-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

/* 通用卡片样式 */
.section-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.section-icon {
  font-size: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

/* 功能网格 */
.features-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 20rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
}

.feature-icon {
  font-size: 56rpx;
  margin-bottom: 16rpx;
}

.feature-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.feature-desc {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  line-height: 1.4;
}

/* 团队列表 */
.team-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.team-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
}

.team-role {
  font-size: 28rpx;
  color: #666;
}

.team-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

/* 联系方式 */
.contact-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.contact-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
}

.contact-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.contact-icon {
  font-size: 40rpx;
}

.contact-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.contact-label {
  font-size: 24rpx;
  color: #999;
}

.contact-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.contact-action {
  font-size: 26rpx;
  color: #FFB800;
  font-weight: bold;
}

/* 操作列表 */
.action-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 0 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.05);
}

.action-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.action-item:last-child {
  border-bottom: none;
}

.action-text {
  font-size: 30rpx;
  color: #333;
}

.action-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.action-value {
  font-size: 26rpx;
  color: #999;
}

.action-stars {
  font-size: 20rpx;
}

.action-arrow {
  font-size: 32rpx;
  color: #ccc;
  font-weight: 300;
}

/* 版权信息 */
.copyright {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 40rpx 20rpx;
}

.copyright-text {
  font-size: 24rpx;
  color: #999;
  text-align: center;
}

