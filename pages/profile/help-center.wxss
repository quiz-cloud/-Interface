/* pages/profile/help-center.wxss */
.container {
  min-height: 100vh;
  background-color: #fbf4e6;
  padding: 24rpx;
  padding-bottom: 40rpx;
}

.page-header {
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.page-subtitle {
  font-size: 28rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

/* 搜索框 */
.search-box {
  position: relative;
  margin-bottom: 24rpx;
}

.search-input {
  width: 100%;
  height: 72rpx;
  background: #fff;
  border-radius: 36rpx;
  padding: 0 56rpx 0 28rpx;
  font-size: 28rpx;
  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.05);
  box-sizing: border-box;
}

.search-icon {
  position: absolute;
  right: 28rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
}

/* 分类标签 */
.category-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
  overflow-x: auto;
  white-space: nowrap;
  -webkit-overflow-scrolling: touch;
}

.category-tabs::-webkit-scrollbar {
  display: none;
}

.category-tab {
  display: inline-block;
  padding: 16rpx 32rpx;
  background: #fff;
  border-radius: 36rpx;
  font-size: 28rpx;
  color: #666;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s;
  flex-shrink: 0;
}

.category-tab.active {
  background: linear-gradient(135deg, #FFB800 0%, #FF9500 100%);
  color: #fff;
  font-weight: bold;
}

/* 问答列表 */
.qa-list {
  margin-bottom: 24rpx;
}

.qa-card {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

.qa-item {
  padding: 28rpx;
}

.question-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.question-icon {
  font-size: 36rpx;
  flex-shrink: 0;
}

.question-text {
  flex: 1;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.5;
}

.expand-icon {
  font-size: 24rpx;
  color: #999;
  flex-shrink: 0;
  transition: transform 0.3s;
}

.answer-content {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
  margin-left: 52rpx;
}

.answer-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  display: block;
}

/* 空状态 */
.empty-state {
  background: #fff;
  border-radius: 20rpx;
  padding: 80rpx 40rpx;
  text-align: center;
  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.05);
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
  display: block;
}

/* 联系卡片 */
.contact-card {
  background: linear-gradient(135deg, #FFF8E7 0%, #FFE8B8 100%);
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 6rpx 18rpx rgba(255, 184, 0, 0.15);
}

.contact-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.contact-icon {
  font-size: 36rpx;
}

.contact-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.contact-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  display: block;
  margin-bottom: 24rpx;
}

.contact-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #FFB800 0%, #FF9500 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 40rpx;
  box-shadow: 0 8rpx 20rpx rgba(255, 184, 0, 0.3);
}

