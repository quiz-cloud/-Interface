/* pages/profile/profile.wxss */
.container {
  padding: 24rpx;
  background-color: #fbf4e6;
  min-height: 100vh;
  box-sizing: border-box;
}

.container {
  padding: 20rpx;
  min-height: 100vh;
  background: #fff3e0;
}

/* 用户卡片 */
.profile-card {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  padding: 40rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(247, 180, 0, 0.12);
}

.profile-card.logged-out {
  justify-content: space-between;
  gap: 24rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: #f2f3f5;
}

.avatar-ghost {
  opacity: 0.5;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 40rpx;
  font-weight: bold;
  color: #2a2a2a;
  margin-bottom: 8rpx;
}

.id-info {
  font-size: 28rpx;
  color: #666;
}

.login-btn {
  background-color: #f7b400;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
}

/* 菜单区域 */
.menu-section {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 列表卡片通用样式 */
.action-list-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 16rpx 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(247, 180, 0, 0.12);
  margin-bottom: 24rpx;
}



/* 操作列表 */
.action-list-card {
  padding: 0 32rpx;
}

.action-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 0;
  border-bottom: 1rpx solid #f2e5c8;
}

.action-item:last-child {
  border-bottom: none;
}

.action-text {
  font-size: 30rpx;
  color: #2a2a2a;
}

.action-picker {
  flex: 1;
  display: flex;
  justify-content: flex-end;
}

.action-value {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #666;
  font-size: 28rpx;
}

.action-value-text {
  color: inherit;
}

.action-item.danger .action-text,
.action-item.danger .arrow {
  color: #cc4c54;
}