/* pages/profile/profile.wxss */

page {
  background-color: #f7f8fa;
}

.container {
  padding: 20rpx;
  min-height: 100vh;
  background: #fff3e0;
}

/* 用户卡片 */
.profile-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.avatar-wrapper {
  margin-right: 24rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: #f2f3f5;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.student-id {
  font-size: 26rpx;
  color: #909399;
}

/* 菜单区域 */
.menu-section {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  font-size: 28rpx;
  color: #333;
  position: relative;
}

.menu-item::after {
  content: "";
  position: absolute;
  left: 30rpx;
  bottom: 0;
  right: 0;
  height: 1rpx;
  background-color: #f2f3f5;
}

.menu-item:last-child::after {
  display: none;
}

.menu-text {
  font-size: 28rpx;
  color: #333;
}

.arrow {
  font-size: 26rpx;
  color: #c0c4cc;
}


/* 语言行右侧容器 */
.lang-wrapper {
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

/* 当前语言文字样式 */
.current-lang {
  font-size: 26rpx;
  color: #909399;
  margin-right: 8rpx;
}

/* 退出登录 */
.logout-section {
  margin-top: 60rpx;
  padding: 0 10rpx;
}

.logout-btn {
  background-color: #fff;
  border-radius: 20rpx;
  text-align: center;
  padding: 26rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.logout-text {
  font-size: 28rpx;
  color: #fa4141;
  font-weight: 500;
}