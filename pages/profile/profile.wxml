<!--pages/profile/profile.wxml-->
<view class="container">
  <!-- 用户信息卡片 -->
  <view class="profile-card">
    <view class="avatar-wrapper">
      <image class="avatar" src="/images/avator/avator_boy.png" mode="aspectFill"></image>
    </view>
    <view class="user-info">
      <text class="nickname">{{user.nickname}}</text>
      <text class="student-id">学号：{{user.studentId}}</text>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="handleAction" data-action="changePwd">
      <text class="menu-text">修改密码</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="handleAction" data-action="changeLang">
      <text class="menu-text">切换语言</text>
      <view class="lang-wrapper">
        <text class="current-lang">{{currentLang}}</text>
        <text class="arrow">></text>
      </view>
    </view>
    <view class="menu-item" bindtap="handleAction" data-action="help">
      <text class="menu-text">帮助中心</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="handleAction" data-action="feedback">
      <text class="menu-text">意见反馈</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="handleAction" data-action="about">
      <text class="menu-text">关于我们</text>
      <text class="arrow">></text>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section">
    <view class="logout-btn" bindtap="handleAction" data-action="logout">
      <text class="logout-text">退出登录</text>
    </view>
  </view>
</view>