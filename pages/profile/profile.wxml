<!--pages/profile/profile.wxml-->
<view class="container">
  <!-- 用户信息卡片 -->
  <view class="profile-card" wx:if="{{isLoggedIn}}">
    <image class="avatar" src="/images/avator/avator_boy.png" mode="aspectFill"></image>
    <view class="user-info">
      <text class="nickname">{{user.nickname}}</text>
      <text class="id-info">{{t.studentId}}: {{user.studentId}}</text>
    </view>
  </view>
  <view class="profile-card logged-out" wx:else>
    <image class="avatar avatar-ghost" src="/images/avator/avator_boy.png" mode="aspectFill"></image>
    <view class="user-info">
      <text class="nickname">{{t.loggedOutTitle}}</text>
      <text class="id-info">{{t.loggedOutSubtitle}}</text>
    </view>
    <button class="login-btn" bindtap="handleLogin">{{t.login}}</button>
  </view>

  <!-- 操作列表 -->
  <view class="action-list-card">
    <view class="action-item" bindtap="handleAction" data-action="help">
      <text class="action-text">{{t.help}}</text>
      <text class="arrow">></text>
    </view>
    <view class="action-item" bindtap="handleAction" data-action="feedback">
      <text class="action-text">{{t.feedback}}</text>
      <text class="arrow">></text>
    </view>
    <view class="action-item" bindtap="handleAction" data-action="about">
      <text class="action-text">{{t.about}}</text>
      <text class="arrow">></text>
    </view>
  </view>

  <view class="action-list-card">
    <view class="action-item">
      <text class="action-text">{{t.language}}</text>
      <picker
        class="action-picker"
        mode="selector"
        range="{{langOptions}}"
        range-key="label"
        value="{{langIndex}}"
        bindchange="handleLanguageChange"
      >
        <view class="action-value">
          <text class="action-value-text">{{langOptions[langIndex].label}}</text>
          <text class="arrow">></text>
        </view>
      </picker>
    </view>
    <view class="action-item" bindtap="handleChangePassword" wx:if="{{isLoggedIn}}">
      <text class="action-text">{{t.changePassword}}</text>
      <text class="arrow">></text>
    </view>
    <view class="action-item danger" bindtap="handleLogout" wx:if="{{isLoggedIn}}">
      <text class="action-text">{{t.logout}}</text>
      <text class="arrow">></text>
    </view>
  </view>
</view>