/* pages/leave/leave.wxss */
.container {
  padding: 24rpx;
  background-color: #fff3e0;
  min-height: 100vh;
  box-sizing: border-box;
}

.page-header {
  margin-bottom: 32rpx;
  padding: 0 16rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.page-subtitle {
  font-size: 28rpx;
  color: #999;
}

.form-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 0 32rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.form-item, .form-item-vertical {
  display: flex;
  align-items: center;
  padding: 32rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child, .form-item-vertical:last-child {
  border-bottom: none;
}

.item-label {
  font-size: 30rpx;
  color: #333;
  width: 180rpx;
}

.item-picker {
  flex: 1;
}

.picker-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 30rpx;
  color: #555;
}

.arrow {
  font-family: sans-serif;
  font-weight: bold;
  color: #ccc;
}

.form-item-vertical {
  flex-direction: column;
  align-items: flex-start;
}

.form-item-vertical .item-label {
  margin-bottom: 20rpx;
}

.item-textarea {
  width: 100%;
  height: 180rpx;
  font-size: 28rpx;
  color: #333;
  background-color: #f9f9f9;
  padding: 16rpx;
  border-radius: 8rpx;
  box-sizing: border-box;
}

/* 请假凭证上传区域 */
.upload-area {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 20rpx;
}

.uploaded-img {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border: 1px solid #eee;
  border-radius: 8rpx;
  overflow: hidden;
  margin-right: 10rpx;
  margin-bottom: 10rpx;
}

.uploaded-img image {
  width: 100%;
  height: 100%;
  display: block;
}

.delete-img {
  position: absolute;
  top: 0rpx;
  right: 0rpx;
  width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  background-color: #ff4d4f;
  color: #ffffff;
  border-radius: 50%;
  font-size: 20rpx;
  font-weight: bold;
  z-index: 999;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.15);
}

.upload-btn {
  width: 160rpx;
  height: 160rpx;
  line-height: 160rpx;
  text-align: center;
  border: 1px dashed #ccc;
  background: #f9f9f9;
  color: #666;
  font-size: 24rpx;
  padding: 0;
  border-radius: 8rpx;
}

.tips-text {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #999;
}

.submit-btn {
  background-color: #007aff;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: bold;
  border-radius: 12rpx;
  margin-top: 40rpx;
}

.history-link {
  text-align: center;
  margin-top: 40rpx;
  font-size: 28rpx;
  color: #007aff;
}
