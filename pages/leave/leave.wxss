
/* pages/leave/leave.wxss */
.container {
  padding: 24rpx;
  background-color: #fff3e0;
  min-height: 100vh;
  box-sizing: border-box;
}

.page-header {
  margin-bottom: 32rpx;
  padding: 0 16rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.page-subtitle {
  font-size: 28rpx;
  color: #999;
}

.form-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 0 32rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.form-item, .form-item-vertical {
  display: flex;
  align-items: center;
  padding: 32rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child, .form-item-vertical:last-child {
  border-bottom: none;
}

.item-label {
  font-size: 30rpx;
  color: #333;
  width: 180rpx;
}

.item-picker {
  flex: 1;
}

.picker-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 30rpx;
  color: #555;
}

.arrow {
  font-family: sans-serif;
  font-weight: bold;
  color: #ccc;
}

.form-item-vertical {
  flex-direction: column;
  align-items: flex-start;
}

.form-item-vertical .item-label {
  margin-bottom: 20rpx;
}

/* 请假凭证上传区域 */
.upload-area {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 20rpx;
}

.uploaded-img {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border: 1px solid #eee;
  border-radius: 8rpx;
  overflow: hidden;
  margin-right: 10rpx;
  margin-bottom: 10rpx;
}

.uploaded-img image {
  width: 100%;
  height: 100%;
  display: block;
}

.delete-img {
  position: absolute;
  top: 0rpx;
  right: 0rpx;
  width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  background-color: #ff4d4f;
  color: #ffffff;
  border-radius: 50%;
  font-size: 20rpx;
  font-weight: bold;
  z-index: 999;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.15);
}

.upload-btn {
  width: 160rpx;
  height: 160rpx;
  line-height: 160rpx;
  text-align: center;
  border: 1px dashed #ccc;
  background: #f9f9f9;
  color: #666;
  font-size: 24rpx;
  padding: 0;
  border-radius: 8rpx;
}

.tips-text {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #999;
}

.submit-btn {
  background-color: #007aff;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: bold;
  border-radius: 12rpx;
  margin-top: 40rpx;
}

.history-link {
  text-align: center;
  margin-top: 40rpx;
  font-size: 28rpx;
  color: #007aff;
}

/* 已选日期区域 */
.selected-dates {
  margin-bottom: 10rpx;
}

.selected-dates .date-header {
  display: flex;
  flex-wrap: wrap;
  align-items: flex-start;
  gap: 10rpx;
}

.selected-dates .title {
  font-size: 28rpx;
  color: #333;
  line-height: 60rpx;
  flex-shrink: 0;
}

.selected-dates .tags-icon-wrapper {
  display: flex;
  flex: 1;
  flex-wrap: wrap;
  align-items: flex-end;
  gap: 16rpx;
}

.selected-dates .tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  flex: 1;
}

.selected-dates .tag {
  background: #e8f4f8;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 26rpx;
  color: #333;
  height: 60rpx;
  box-sizing: border-box;
}

.selected-dates .close {
  color: #ff4757;
  font-size: 30rpx;
  line-height: 1;
  cursor: pointer;
}

.selected-dates .toggle-icon {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f5f5f5;
  cursor: pointer;
  flex-shrink: 0;
  margin-bottom: 2rpx;
}

.selected-dates .calendar-icon {
  width: 32rpx;
  height: auto;
  transition: transform 0.2s ease-in-out;
}

.selected-dates .rotate-icon {
  transform: rotate(180deg);
}

.selected-dates .toggle-icon:active {
  background: #e9e9e9;
  transform: scale(0.95);
}

/* 日历容器 */
.calendar-container {
  width: 100%;
  margin: 10rpx 0;
  animation: fadeIn 0.2s ease-in-out;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 日历头部 */
.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.calendar-header .btn {
  background: #f5f5f5;
  border: none;
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.calendar-header .month-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

/* 星期头部 */
.week-header {
  display: flex;
  background: #f8f9fa;
  border-radius: 8rpx 8rpx 0 0;
}

.week-header .week-item {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  font-size: 24rpx;
  color: #666;
}

/* 日期格子 */
.days {
  display: flex;
  flex-wrap: wrap;
  border: 1rpx solid #eee;
  border-top: none;
  border-radius: 0 0 8rpx 8rpx;
}

.day-item {
  width: calc(100% / 7);
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  box-sizing: border-box;
  border: 1rpx solid #eee;
  border-top: none;
  border-left: none;
  color: #333;
}

.day-item.empty {
  background: #fafafa;
}

.day-item.today {
  background: #e8f4f8;
  font-weight: bold;
}

.day-item.selected {
  background: #07c160;
  color: white;
}

.day-item.disabled {
  color: #cccccc;
  background: #f9f9f9;
  cursor: not-allowed;
}

.day-item.disabled:active {
  background: #f9f9f9 !important;
}

.day-item.selected.disabled {
  background: #07c160;
  color: white;
}

.day-item:active:not(.empty):not(.selected):not(.disabled) {
  background: #f0f0f0;
}